# PostgreSQL is the only supported IMMUNICARE database target.
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=your_password_here
PG_DATABASE=immunicare
PG_POOL_MAX=10
PG_IDLE_TIMEOUT_MS=30000

PORT=3000
CORS_ORIGIN=http://localhost:5173
JWT_SECRET=replace_with_a_long_random_secret

# SMS provider configuration.
# Use mock mode during development/capstone testing when live Semaphore credentials are unavailable.
SMS_PROVIDER=mock
SMS_MOCK_MODE=true
SMS_SENDER_NAME=IMMUNICARE
SMS_PROVIDER_TIMEOUT_MS=10000
SEMAPHORE_API_URL=https://api.semaphore.co/api/v4/messages
SEMAPHORE_API_KEY=

# Caregiver OTP security.
OTP_PEPPER=replace_with_a_long_random_otp_pepper
CAREGIVER_SESSION_SECONDS=14400
